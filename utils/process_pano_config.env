# Configuration for SD-T2I-360PanoImage

# Default Prompt for Text-to-Pano
PROMPT="A living room"

# Default Prompt for Image-to-Pano (often empty or describing the scene)
# If empty, the script may prompt or use the T2P prompt.
I2P_PROMPT="A living room"

# Upscale: True or False
UPSCALE="False"

# Default Resolution settings (if applicable, usually fixed by model)
# BALL_SIZE, etc. are for the other project, here we might have specific params.

# Output Directory (relative to script execution or absolute)
# If empty, saves next to input or in current dir.
OUTPUT_DIR=""

