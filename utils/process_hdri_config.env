# DiffusionLight Configuration
# Resolution Settings

# Size of the chrome ball in the 1024x1024 input image
# Default: 256. increased to 512 for higher resolution reflection
# Note: Max size is 1004 (1024 - 20 padding). Using 512 for better quality/context balance.
BALL_SIZE=512

# Height of the output environment map (width will be 2x height)
# Default: 256 (512x256 output). Increased to 1024 (2048x1024 output)
ENVMAP_HEIGHT=1024

# Quality Settings
# Algorithm: turbo_swapping (fast, default), iterative (slow, better quality)
ALGORITHM="turbo_swapping"

# Denoising steps (default 30). Higher = potential better quality but slower.
DENOISING_STEPS=60

# Prompt engineering
PROMPT="a perfect mirrored reflective chrome ball sphere"
NEGATIVE_PROMPT="matte, diffuse, flat, dull"


